---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort((a, b) => b.data.number - a.data.number);
const totalCount = posts.length;

function getOpener(body: string | undefined): string {
  if (!body) return '';
  const first = body.split('\n\n').filter((p: string) => p.trim())[0] || '';
  const cleaned = first.replace(/\n/g, ' ').trim();
  const match = cleaned.match(/^[^.!?]+[.!?]/);
  return match ? match[0] : cleaned.slice(0, 140) + (cleaned.length > 140 ? '...' : '');
}
---

<Base title="Exhibits" description="The Book of Han — the record of unjust suffering that was never resolved." pageType="page">
  <section class="handbook-section">
    <h2 class="handbook-title">The Book of Han</h2>
    <p class="handbook-description">Han (&#54620;) — the deep, accumulated weight of unjust suffering that was never resolved. {totalCount} exhibits filed. Anonymous. No names, no breadcrumbs.</p>
  </section>

  <section class="stories-section">
    <div class="stories-label">{totalCount} exhibits</div>
    <div class="story-grid">
      {posts.map((post, i) => {
        const num = String(post.data.number).padStart(3, '0');
        const opener = getOpener(post.body);
        const tags = post.data.tags ? post.data.tags.split(',').map((t: string) => t.trim()).slice(0, 3) : [];
        return (
          <a href={`/posts/${post.id}`} class={`story-card${i === 0 ? ' story-card-featured' : ''}`}>
            <div class="story-card-hero">
              <span class="story-card-hero-mark" aria-hidden="true">&#54620;</span>
              <span class="story-card-hero-num">EX-{num}</span>
            </div>
            <div class="story-card-body">
              <span class="story-card-brand">The Book of Han</span>
              <h3 class="story-card-title">{post.data.title}</h3>
              <p class="story-card-opener">{opener}</p>
              {tags.length > 0 && (
                <div class="story-card-tags">
                  {tags.map((t: string) => <span class="story-card-tag">{t}</span>)}
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Base>
