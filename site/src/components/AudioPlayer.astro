---
const { slug } = Astro.props;
const audioUrl = `https://hancock-agent.bitter-sky-a8a5.workers.dev/media/audio/${slug}.mp3`;
---

<div class="audio-player" data-audio-url={audioUrl} data-audio-state="checking">
  <button class="audio-btn" aria-label="Listen to this exhibit">
    <svg class="audio-icon audio-icon-play" width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M4 2.5v11l9-5.5L4 2.5z" fill="currentColor"/>
    </svg>
    <svg class="audio-icon audio-icon-pause" width="16" height="16" viewBox="0 0 16 16" fill="none" style="display:none">
      <rect x="3" y="2" width="3.5" height="12" fill="currentColor"/>
      <rect x="9.5" y="2" width="3.5" height="12" fill="currentColor"/>
    </svg>
    <span class="audio-label">Listen</span>
  </button>
  <div class="audio-progress" style="display:none">
    <div class="audio-bar">
      <div class="audio-fill"></div>
    </div>
    <span class="audio-time">0:00</span>
  </div>
</div>

<style>
  /* Hidden by default until HEAD check confirms audio exists.
     Avoids the "Listen → click → Unavailable" broken-looking UX. */
  .audio-player[data-audio-state="checking"],
  .audio-player[data-audio-state="missing"] {
    display: none !important;
  }
  .audio-player[data-audio-state="ready"] {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 20px 0;
    padding: 12px 16px;
    border-left: 3px solid #8b3a3a;
    background: rgba(139, 58, 58, 0.06);
  }
  .audio-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    color: #8b3a3a;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0;
    white-space: nowrap;
  }
  .audio-btn:hover {
    color: #a85050;
  }
  .audio-icon {
    flex-shrink: 0;
  }
  .audio-progress {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    min-width: 0;
  }
  .audio-bar {
    flex: 1;
    height: 3px;
    background: rgba(139, 58, 58, 0.2);
    cursor: pointer;
    position: relative;
  }
  .audio-fill {
    height: 100%;
    background: #8b3a3a;
    width: 0%;
    transition: width 0.1s linear;
  }
  .audio-time {
    color: #6b6560;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    flex-shrink: 0;
  }
</style>

<script>
  document.querySelectorAll('.audio-player').forEach(async (player) => {
    const el = player as HTMLElement;
    const url = el.dataset.audioUrl!;

    // Runtime HEAD check — hide the player if audio doesn't exist in KV.
    // Decision 9 (2026-05-13): "Listen → click → Unavailable" reads broken,
    // so we pre-check at page load instead of letting click discover 404.
    try {
      const resp = await fetch(url, { method: 'HEAD' });
      if (!resp.ok) {
        el.dataset.audioState = 'missing';
        return;
      }
    } catch {
      el.dataset.audioState = 'missing';
      return;
    }

    el.dataset.audioState = 'ready';

    const btn = player.querySelector('.audio-btn') as HTMLButtonElement;
    const label = player.querySelector('.audio-label') as HTMLElement;
    const playIcon = player.querySelector('.audio-icon-play') as HTMLElement;
    const pauseIcon = player.querySelector('.audio-icon-pause') as HTMLElement;
    const progress = player.querySelector('.audio-progress') as HTMLElement;
    const fill = player.querySelector('.audio-fill') as HTMLElement;
    const timeEl = player.querySelector('.audio-time') as HTMLElement;
    const bar = player.querySelector('.audio-bar') as HTMLElement;
    let audio: HTMLAudioElement | null = null;

    function formatTime(s: number) {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    btn.addEventListener('click', async () => {
      if (!audio) {
        audio = new Audio(url);
        audio.addEventListener('timeupdate', () => {
          if (audio!.duration) {
            fill.style.width = (audio!.currentTime / audio!.duration * 100) + '%';
            timeEl.textContent = formatTime(audio!.currentTime);
          }
        });
        audio.addEventListener('ended', () => {
          playIcon.style.display = '';
          pauseIcon.style.display = 'none';
          label.textContent = 'Listen';
          fill.style.width = '0%';
        });
        audio.addEventListener('error', () => {
          label.textContent = 'Unavailable';
          btn.disabled = true;
        });
      }

      if (audio.paused) {
        await audio.play();
        playIcon.style.display = 'none';
        pauseIcon.style.display = '';
        label.textContent = 'Pause';
        progress.style.display = '';
      } else {
        audio.pause();
        playIcon.style.display = '';
        pauseIcon.style.display = 'none';
        label.textContent = 'Play';
      }
    });

    bar?.addEventListener('click', (e: MouseEvent) => {
      if (audio?.duration) {
        const rect = bar.getBoundingClientRect();
        const pct = (e.clientX - rect.left) / rect.width;
        audio.currentTime = pct * audio.duration;
      }
    });
  });
</script>
